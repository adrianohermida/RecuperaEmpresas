# ── Supabase ──────────────────────────────────────────────────────────────────
# Nomes VITE_* = convenção do projeto (usados também como Edge Function secrets)
VITE_SUPABASE_URL=https://<seu-projeto>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon key — Supabase → Settings → API>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable key — Supabase → Settings → API>
# OBRIGATÓRIO para o servidor funcionar (bypass de RLS):
VITE_SUPABASE_SERVICE_ROLE=<service_role key — Supabase → Settings → API>

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=<string secreta longa e aleatória>
ADMIN_EMAILS=contato@recuperaempresas.com.br,seuemail@dominio.com
# Senha inicial das contas admin criadas automaticamente na primeira inicialização
ADMIN_DEFAULT_PASSWORD=<senha segura>

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=<chave da API do Resend — resend.com>
EMAIL_FROM=Portal Recupera Empresas <portal@seudominio.com.br>
EMAIL_TO=contato@seudominio.com.br

# ── Freshdesk ─────────────────────────────────────────────────────────────────
FRESHDESK_API_KEY=<API Key do Freshdesk — Profile Settings>

# ── Freshsales ────────────────────────────────────────────────────────────────
FRESHSALES_ALIAS_DOMAIN=seusubdominio
FRESHSALES_API_KEY=<API Key do Freshsales>

# ── Freshchat ─────────────────────────────────────────────────────────────────
FRESHCHAT_API_KEY=<API Key do Freshchat>
FRESHCHAT_ALIAS_DOMAIN=seusubdominio
FRESHCHAT_JWT_SECRET=<secret base64 do painel Freshchat>

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=<sk_live_... ou sk_test_... — dashboard.stripe.com>
STRIPE_PUBLIC_KEY=<pk_live_... ou pk_test_...>
STRIPE_API_KEY=<mesma que STRIPE_SECRET_KEY — alias>
STRIPE_ACCOUNT_ID=<acct_... — Stripe → Settings → Account details>
STRIPE_WEBHOOK_SECRET=<whsec_... — Stripe → Developers → Webhooks>

# ── Google Calendar (integração agenda ↔ Google Calendar do agente) ───────────
# Passo a passo para obter as credenciais:
#   1. Google Cloud Console → IAM → Service Accounts → Create Service Account
#   2. Conceder papel "Editor de Calendário" ou nenhum papel (apenas API scope)
#   3. Criar chave JSON para essa conta de serviço → baixar o arquivo
#   4. No Google Calendar do agente: Configurações do calendário → Compartilhar
#      → adicionar o e-mail da service account com permissão "Fazer alterações em eventos"
#   5. Copiar os valores abaixo do arquivo JSON baixado:
GOOGLE_CLIENT_EMAIL=nome-sa@projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# ID do calendário do agente — geralmente o e-mail dele; ou copie de
# Configurações do calendário → "ID do calendário" (no final da página)
GOOGLE_CALENDAR_ID=agente@recuperaempresas.com.br
# Fuso horário dos eventos (padrão: America/Sao_Paulo)
GOOGLE_CALENDAR_TZ=America/Sao_Paulo

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
