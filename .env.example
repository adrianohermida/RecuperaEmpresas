# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_ANON_KEY=<anon key — Supabase → Settings → API>
# OBRIGATÓRIO para o servidor funcionar:
SUPABASE_SERVICE_ROLE_KEY=<service_role key — Supabase → Settings → API>

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=<string secreta longa e aleatória>
ADMIN_EMAILS=contato@recuperaempresas.com.br,seuemail@dominio.com

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=<chave da API do Resend — resend.com>
EMAIL_FROM=Portal Recupera Empresas <portal@seudominio.com.br>
EMAIL_TO=contato@seudominio.com.br

# ── Freshdesk ─────────────────────────────────────────────────────────────────
FRESHDESK_DOMAIN=seusubdominio
FRESHDESK_KEY=<API Key do Freshdesk — Profile Settings>

# ── Freshchat JWT ─────────────────────────────────────────────────────────────
FRESHCHAT_JWT_SECRET=<secret base64 do painel Freshchat>

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
